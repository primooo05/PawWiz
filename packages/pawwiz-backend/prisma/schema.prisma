// PawWiz Database Schema
// Application-specific data only â€” user credentials live in Supabase Auth
// Connection URL is configured in prisma.config.ts (Prisma 7+)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

model Profile {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique @map("supabase_user_id")
  displayName    String   @map("display_name")
  catName        String   @map("cat_name")
  catBreed       String?  @map("cat_breed")
  catMarking     String?  @map("cat_marking")
  catSex         String   @map("cat_sex")
  catLifeStage   String   @map("cat_life_stage")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  dietProfiles   DietProfile[]
  cats           Cat[]

  @@map("profiles")
}

model OnboardingSession {
  id              String   @id @default(uuid())
  step            Int      @default(1)
  ownerName       String?  @map("owner_name")
  ownerEmail      String?  @map("owner_email")
  otpHash         String?  @map("otp_hash")
  otpExpiresAt    DateTime? @map("otp_expires_at")
  otpVerified     Boolean  @default(false) @map("otp_verified")
  otpLastSentAt   DateTime? @map("otp_last_sent_at")
  otpAttempts     Int      @default(0) @map("otp_attempts")
  catsCount       String?  @map("cats_count")
  customCatsCount String?  @map("custom_cats_count")
  catName         String?  @map("cat_name")
  catBreed        String?  @map("cat_breed")
  catMarking      String?  @map("cat_marking")
  catSex          String?  @map("cat_sex")
  catLifeStage    String?   @map("cat_life_stage")
  consumedAt      DateTime? @map("consumed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  cats            Cat[]

  @@index([ownerEmail])
  @@map("onboarding_sessions")
}

model DietProfile {
  id              String   @id @default(cuid())
  profileId       String   @map("profile_id")
  catId           String?  @map("cat_id")
  weight          Float
  isKg            Boolean  @map("is_kg")
  foodPreference  String   @map("food_preference")
  isSpayedNeutered Boolean @map("is_spayed_neutered")
  isTracking      Boolean  @default(false) @map("is_tracking")
  waterIntake     Int      @default(0) @map("water_intake")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  profile    Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  cat        Cat?           @relation(fields: [catId], references: [id], onDelete: Cascade)
  mealLogs   DietMealLog[]

  @@index([profileId])
  @@map("diet_profiles")
}

model Cat {
  id        String   @id @default(cuid())
  profileId String?  @map("profile_id")
  name      String
  breed     String?
  marking   String?
  sex       String
  lifeStage String   @map("life_stage")
  age       Int?
  photoUrl  String?  @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile                 Profile?                @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dietProfiles            DietProfile[]
  onboardingSessionId     String?                 @map("onboarding_session_id")
  onboardingSession       OnboardingSession?      @relation(fields: [onboardingSessionId], references: [id], onDelete: Cascade)
  healthTimelineInsights  HealthTimelineInsight[]
  pregnancySessions       PregnancySession[]
  behaviorChats           BehaviorChat[]

  @@index([profileId])
  @@map("cats")
}

model DietMealLog {
  id            String   @id @default(cuid())
  dietProfileId String   @map("diet_profile_id")
  mealName      String   @map("meal_name")
  foodType      String?  @map("food_type")
  amount        Float?
  unit          String?
  kcal          Float?
  status        String
  timestamp     String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dietProfile   DietProfile @relation(fields: [dietProfileId], references: [id], onDelete: Cascade)

  @@index([dietProfileId, createdAt])
  @@map("diet_meal_logs")
}

model Plant {
  id             String    @id @default(cuid())
  commonName     String    @map("common_name")
  scientificName String    @unique @map("scientific_name")
  toxicityStatus String    @map("toxicity_status")  // 'toxic' | 'caution' | 'safe'
  severity       String?                             // 'mild' | 'moderate' | 'severe' | 'lethal' | null
  clinicalSigns  String[]  @map("clinical_signs")
  source         String                              // 'aspca' | 'perenual_cache'
  mediaUrl       String?   @map("media_url")
  perenualId     String?   @map("perenual_id")
  physicalDescription String?   @map("physical_description")
  cachedAt       DateTime? @map("cached_at")
  lastVerifiedAt DateTime  @map("last_verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // B-tree indexes remain for exact/prefix lookups; the trigram GIN indexes
  // below accelerate the case-insensitive substring (ILIKE '%term%') matching
  // used by findByCommonName / findByScientificName.
  @@index([scientificName])
  @@index([commonName])
  @@index([commonName(ops: raw("gin_trgm_ops"))], type: Gin, name: "plants_common_name_trgm_idx")
  @@index([scientificName(ops: raw("gin_trgm_ops"))], type: Gin, name: "plants_scientific_name_trgm_idx")
  @@map("plants")
}

model BehaviorChat {
  id             String   @id @default(cuid())
  supabaseUserId String   @map("supabase_user_id")
  catId          String?  @map("cat_id")   // nullable: null = legacy/user-scoped system chats
  title          String   @default("New Chat")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  cat            Cat?             @relation(fields: [catId], references: [id], onDelete: SetNull)
  messages       BehaviorMessage[]
  behaviorLogs   BehaviorLog[]

  @@index([supabaseUserId])
  @@index([supabaseUserId, catId])
  @@map("behavior_chats")
}

model BehaviorMessage {
  id        String   @id @default(cuid())
  chatId    String   @map("chat_id")
  speaker   String                        // 'wiz' | 'user'
  text      String
  analysis  Json?                          // BehaviorDecodeResponse JSON when speaker is 'wiz'
  createdAt DateTime @default(now()) @map("created_at")

  chat BehaviorChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("behavior_messages")
}

enum InsightSeverity {
  info
  warning
  concern
}

model HealthTimelineInsight {
  id          String          @id @default(uuid())
  catId       String          @map("cat_id")
  type        String          @db.VarChar(100)
  summary     String          @db.VarChar(160)
  detail      String          @db.VarChar(500)
  severity    InsightSeverity
  eventIds    Json            @map("event_ids")
  source      String          @db.VarChar(20)
  generatedAt DateTime        @map("generated_at") @db.Timestamptz
  createdAt   DateTime        @default(now())      @map("created_at")
  updatedAt   DateTime        @updatedAt           @map("updated_at")

  cat Cat @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, generatedAt(sort: Desc)])
  @@index([catId, type])
  @@unique([catId, type, generatedAt])
  @@map("health_timeline_insights")
}

model BehaviorLog {
  id             String   @id @default(cuid())
  chatId         String   @map("chat_id")
  supabaseUserId String   @map("supabase_user_id")
  catId          String?  @map("cat_id")
  behaviorType   String   @map("behavior_type")   // 'playful', 'anxious', 'aggressive', 'lethargic', 'affectionate', etc.
  intensity      String                           // 'mild', 'moderate', 'severe'
  description    String                           // e.g. "Cat sprinting around house at 2 AM"
  context        String?                          // e.g. "night time", "after meal"
  extractedFrom  String   @map("extracted_from")  // description of the user message it came from
  confidence     Float    @default(0.5)           // 0-1 scale: how confident we are about this behavior classification
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  chat BehaviorChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([supabaseUserId])
  @@index([chatId])
  @@index([catId])
  @@index([behaviorType])
  @@index([createdAt])
  @@map("behavior_logs")
}

// ─── Cat Pregnancy Tracker (Flo-style daily logging) ─────────────────────────

model PregnancySession {
  id                   String         @id @default(cuid())
  catId                String         @map("cat_id")
  matingDate           DateTime       @map("mating_date")
  status               String         @default("active") @map("status") // 'active' | 'completed'
  expectedDeliveryDate DateTime       @map("expected_delivery_date")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  cat                  Cat                @relation(fields: [catId], references: [id], onDelete: Cascade)
  pregnancyLogs        PregnancyLog[]
  pregnancyInsights    PregnancyInsight[]

  @@index([catId])
  @@index([catId, status])
  @@map("pregnancy_sessions")
}

model PregnancyLog {
  id                 String   @id @default(cuid())
  pregnancySessionId String   @map("pregnancy_session_id")

  // ── Flo-style chip fields (primary input) ──────────────────────────────
  symptoms           String[] @map("symptoms")       // validated against SYMPTOM_CHIPS
  moodBehavior       String[] @map("mood_behavior")  // validated against MOOD_CHIPS
  appetiteLevel      String?  @map("appetite_level")  // APPETITE_LEVELS enum (service-validated)
  energyLevel        String?  @map("energy_level")    // ENERGY_LEVELS enum (service-validated)
  nestingObserved    Boolean  @default(false) @map("nesting_observed")

  // ── Numeric measurements (optional, secondary) ─────────────────────────
  weight             Float?   @map("weight")
  temp               Float?   @map("temp")

  // ── Gestation context (computed server-side, denormalized for history) ──
  gestationWeek      Int      @map("gestation_week")

  // ── Notes (optional, secondary to chips; sanitized before storage) ─────
  notes              String?  @map("notes")

  logDate            DateTime @map("log_date")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  pregnancySession   PregnancySession @relation(fields: [pregnancySessionId], references: [id], onDelete: Cascade)

  @@index([pregnancySessionId])
  @@index([gestationWeek])
  @@map("pregnancy_logs")
}

model PregnancyInsight {
  id                 String   @id @default(cuid())
  pregnancySessionId String   @map("pregnancy_session_id")
  insightType        String   @map("insight_type") // 'pattern_detected' | 'milestone_reached' | 'vet_reminder' | 'warning'
  title              String   @map("title")
  body               String   @map("body")
  gestationWeek      Int      @map("gestation_week")
  isRead             Boolean  @default(false) @map("is_read")
  createdAt          DateTime @default(now()) @map("created_at")

  pregnancySession   PregnancySession @relation(fields: [pregnancySessionId], references: [id], onDelete: Cascade)

  @@index([pregnancySessionId])
  @@index([pregnancySessionId, isRead])
  @@map("pregnancy_insights")
}
