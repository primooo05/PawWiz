// PawWiz Database Schema
// Application-specific data only — user credentials live in Supabase Auth
// Connection URL is configured in prisma.config.ts (Prisma 7+)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique @map("supabase_user_id")
  displayName    String   @map("display_name")
  catName        String   @map("cat_name")
  catBreed       String?  @map("cat_breed")
  catMarking     String?  @map("cat_marking")
  catSex         String   @map("cat_sex")
  catLifeStage   String   @map("cat_life_stage")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  dietProfiles   DietProfile[]
  cats           Cat[]

  @@map("profiles")
}

model OnboardingSession {
  id              String   @id @default(uuid())
  step            Int      @default(1)
  ownerName       String?  @map("owner_name")
  ownerEmail      String?  @map("owner_email")
  otpHash         String?  @map("otp_hash")
  otpExpiresAt    DateTime? @map("otp_expires_at")
  otpVerified     Boolean  @default(false) @map("otp_verified")
  otpLastSentAt   DateTime? @map("otp_last_sent_at")
  catsCount       String?  @map("cats_count")
  customCatsCount String?  @map("custom_cats_count")
  catName         String?  @map("cat_name")
  catBreed        String?  @map("cat_breed")
  catMarking      String?  @map("cat_marking")
  catSex          String?  @map("cat_sex")
  catLifeStage    String?   @map("cat_life_stage")
  consumedAt      DateTime? @map("consumed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("onboarding_sessions")
}

model DietProfile {
  id              String   @id @default(cuid())
  profileId       String   @map("profile_id")
  catId           String?  @map("cat_id")
  weight          Float
  isKg            Boolean  @map("is_kg")
  foodPreference  String   @map("food_preference")
  isSpayedNeutered Boolean @map("is_spayed_neutered")
  isTracking      Boolean  @default(false) @map("is_tracking")
  waterIntake     Int      @default(0) @map("water_intake")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  profile    Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  cat        Cat?           @relation(fields: [catId], references: [id], onDelete: Cascade)
  mealLogs   DietMealLog[]

  @@map("diet_profiles")
}

model Cat {
  id        String   @id @default(cuid())
  profileId String?  @map("profile_id")
  name      String
  breed     String?
  marking   String?
  sex       String
  lifeStage String   @map("life_stage")
  age       Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile      Profile?      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  dietProfiles DietProfile[]

  @@map("cats")
}

model DietMealLog {
  id            String   @id @default(cuid())
  dietProfileId String   @map("diet_profile_id")
  mealName      String   @map("meal_name")
  foodType      String?  @map("food_type")
  amount        Float?
  unit          String?
  kcal          Float?
  status        String
  timestamp     String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  dietProfile   DietProfile @relation(fields: [dietProfileId], references: [id], onDelete: Cascade)

  @@map("diet_meal_logs")
  @@unique([dietProfileId, mealName])
}

model Plant {
  id             String    @id @default(cuid())
  commonName     String    @map("common_name")
  scientificName String    @unique @map("scientific_name")
  toxicityStatus String    @map("toxicity_status")  // 'toxic' | 'caution' | 'safe'
  severity       String?                             // 'mild' | 'moderate' | 'severe' | 'lethal' | null
  clinicalSigns  String[]  @map("clinical_signs")
  source         String                              // 'aspca' | 'perenual_cache'
  mediaUrl       String?   @map("media_url")
  perenualId     String?   @map("perenual_id")
  cachedAt       DateTime? @map("cached_at")
  lastVerifiedAt DateTime  @map("last_verified_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([scientificName])
  @@index([commonName])
  @@map("plants")
}
