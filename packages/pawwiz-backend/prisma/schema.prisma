// PawWiz Database Schema
// Application-specific data only — user credentials live in Supabase Auth
// Connection URL is configured in prisma.config.ts (Prisma 7+)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id             String   @id @default(cuid())
  supabaseUserId String   @unique @map("supabase_user_id")
  displayName    String   @map("display_name")
  catName        String   @map("cat_name")
  catBreed       String?  @map("cat_breed")
  catMarking     String?  @map("cat_marking")
  catSex         String   @map("cat_sex")
  catLifeStage   String   @map("cat_life_stage")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  dietProfiles   DietProfile[]

  @@map("profiles")
}

model OnboardingSession {
  id              String   @id @default(uuid())
  step            Int      @default(1)
  ownerName       String?  @map("owner_name")
  ownerEmail      String?  @map("owner_email")
  catsCount       String?  @map("cats_count")
  customCatsCount String?  @map("custom_cats_count")
  catName         String?  @map("cat_name")
  catBreed        String?  @map("cat_breed")
  catMarking      String?  @map("cat_marking")
  catSex          String?  @map("cat_sex")
  catLifeStage    String?   @map("cat_life_stage")
  consumedAt      DateTime? @map("consumed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("onboarding_sessions")
}

model DietProfile {
  id               String        @id @default(cuid())
  profileId        String        @map("profile_id")
  name             String
  gender           String        // 'male' | 'female'
  lifeStage        String        // 'kitten' | 'adult'
  age              Int           // months for kitten, years for adult
  weight           Float
  isKg             Boolean       @map("is_kg")
  foodPreference   String        @map("food_preference") // 'dry' | 'wet' | 'mixed'
  isSpayedNeutered Boolean       @map("is_spayed_neutered")
  isTracking       Boolean       @default(false) @map("is_tracking")
  waterIntake      Int           @default(0) @map("water_intake")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  profile          Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  loggedMeals      DietMealLog[]

  @@map("diet_profiles")
}

model DietMealLog {
  id            String      @id @default(cuid())
  dietProfileId String      @map("diet_profile_id")
  mealName      String      @map("meal_name") // 'Breakfast' | 'Lunch' | 'Dinner'
  foodType      String?     @map("food_type") // 'dry' | 'wet' | 'mixed'
  amount        Float?
  unit          String?     // 'spoon' | 'cup'
  kcal          Float
  status        String      // 'pending' | 'logged' | 'skipped'
  timestamp     String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  dietProfile   DietProfile @relation(fields: [dietProfileId], references: [id], onDelete: Cascade)

  @@map("diet_meal_logs")
}


