# PawWiz — monorepo environment template.
# Copy this file to `.env` in the repo root and fill in the values:
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows cmd)
#
# A single root `.env` serves both packages:
#   - Backend loads the nearest `.env` walking up from its cwd (src/lib/env.ts)
#     and Prisma tooling does the same (prisma.config.ts).
#   - The frontend reads this file via Vite (envDir points at the repo root);
#     only VITE_-prefixed vars are exposed to the browser.
#
# Infisical is optional — running under `infisical run --` injects the same
# variables and takes precedence over this file.

# ===========================================================================
# BACKEND
# ===========================================================================

# --- Database (PostgreSQL / Supabase) -------------------------------------
# Pooled connection used at runtime (?pgbouncer=true is stripped for pg driver).
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
# Direct (non-pooled) connection used for Prisma migrations.
DIRECT_URL=postgresql://user:password@host:5432/postgres
# Shadow DB used by `prisma migrate dev` (optional).
SHADOW_DATABASE_URL=

# --- Server ----------------------------------------------------------------
PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# --- Supabase auth ---------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/reset-password

# --- AI providers (optional — app falls back to mocks when absent) ---------
GEMINI_API_KEY=
GROQ_API_KEY=

# --- External plant integrations (optional) --------------------------------
PLANTNET_API_KEY=
PERENUAL_API_KEY=

# --- Email / OTP (optional — send is skipped when absent) ------------------
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ===========================================================================
# FRONTEND (Vite — only VITE_-prefixed vars reach the browser)
# ===========================================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
